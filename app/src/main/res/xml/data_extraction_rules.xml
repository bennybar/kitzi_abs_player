<?xml version="1.0" encoding="utf-8"?>
<!--
  What may leave the device on cloud backup or a device-to-device transfer.

  Nothing here is worth restoring and some of it is actively harmful to restore:

  - The refresh token lives in EncryptedSharedPreferences (kitzi_secure), whose
    master key is held in the Android Keystore and is NEVER backed up or
    transferred. A restored copy therefore cannot be decrypted, and
    EncryptedSharedPreferences.create() throws on that file — a crash on first
    launch after a device migration, at the worst possible moment for the user.
  - The plain prefs hold the access token and the server URL. A settings backup
    is not a place for credentials; the app already offers an explicit
    Settings > Backup export for the preferences people actually want to move.
  - The Room caches and downloaded audio are re-fetchable from the server and
    can run to gigabytes.

  Everything is therefore excluded, and a migrated user signs in once. Note the
  app also sets android:allowBackup="false", which covers cloud backup on
  Android 11 and below; these rules additionally govern device transfer on 12+.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
